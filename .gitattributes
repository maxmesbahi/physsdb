# Git LFS — track binary weight + sample-tile artefacts so cloning stays fast.
# Install LFS once on each machine:  git lfs install
runs/**/*.pt          filter=lfs diff=lfs merge=lfs -text
runs/**/*.npz         filter=lfs diff=lfs merge=lfs -text
runs/**/*.png         filter=lfs diff=lfs merge=lfs -text
data/sample/**/*.tif  filter=lfs diff=lfs merge=lfs -text
data/sample/**/*.npy  filter=lfs diff=lfs merge=lfs -text
*.tar.gz              filter=lfs diff=lfs merge=lfs -text
