# Keep the build context tiny

# VCS
.git/
.gitattributes
.gitignore

# Python noise
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local dev artefacts
*.log
.env
.venv/
venv/
.idea/
.vscode/

# Don't ship the giant raw dataset or the ~6 GB MagicBathyNet.zip
data/magicbathynet/
*.zip

# Things that should *not* be COPYed (we mount them or supply via Git LFS)
# runs/  ← keep enabled so the COPY succeeds; the COPY tolerates an empty dir
# data/  ← same

# Docs & meta
*.md
LICENSE
.github/
docs/
